# AI Provider Configuration
# Options: anthropic, openai, ollama
# AI_PROVIDER=anthropic

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# AI Model to use
# For Anthropic: claude-sonnet-4-20250514, claude-3-5-haiku-20241022 (cheaper)
# For OpenAI: gpt-4o-mini (cheaper), gpt-4o
# For Ollama: llama3, mistral, etc.
# AI_MODEL=claude-sonnet-4-20250514

# Ollama Base URL (only needed if using Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# PostgreSQL Database URL
DATABASE_URL=postgresql://indian_biased:indian_biased_password@host.docker.internal:5432/indian_biased

# Pipeline interval in hours
PIPELINE_INTERVAL_HOURS=3

AI_PROVIDER=ollama
AI_MODEL=llama3
OLLAMA_BASE_URL=http://host.docker.internal:11434
